{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["DOM", "ES2022"],
    "outDir": "dist/core/injected",
    "rootDir": "core/injected",
    "strict": true,
    "noEmitHelpers": true,
    "removeComments": false,
    "skipLibCheck": true
  },
  "include": ["core/injected/*.ts"],
  "exclude": ["core/injected/index.ts"]
}
